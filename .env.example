# =============================================================================
# NanoAssist — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# CRM / WhatsApp (Dix como padrão)
# -----------------------------------------------------------------------------
CRM_PROVIDER=dix
CRM_BASE_URL=
CRM_TOKEN=
CRM_SEND_MESSAGE_PATH=/api/messages/send

# Dix CRM (fallback específico)
DIX_BASE_URL=
DIX_TOKEN=
DIX_SEND_MESSAGE_PATH=/api/messages/send

# Legado MediPharma (compatibilidade)
MEDIPHARMA_TOKEN=
MEDIPHARMA_BASE_URL=https://api.medipharma.com.br

# -----------------------------------------------------------------------------
# ReceitaFace (consulta de receitas)
# -----------------------------------------------------------------------------
RECEITAFACE_TOKEN=seu_bearer_token_receitaface
RECEITAFACE_BASE_URL=https://app.receitaface.com.br
RECEITAFACE_RECIPE_SEARCH_PATH=/api/recipes/search
RECEITAFACE_QUERY_PARAM=q

# Modo session (workaround temporário — use apenas se não houver token oficial)
RECEITAFACE_USE_SESSION=false
RECEITAFACE_SESSION_COOKIE=
RECEITAFACE_CSRF_TOKEN=
RECEITAFACE_LIST_PATH=/receita/data/todas
RECEITAFACE_DETAILS_PATH=/receita/visualizar/detalhes
RECEITAFACE_REFERER_PATH=/receita/visualizar/todas
RECEITAFACE_PAGE_LENGTH=10

# Mock (ative apenas em desenvolvimento — desative em produção)
RECEITAFACE_MOCK_ENABLED=false
RECEITAFACE_MOCK_DELAY_MS=0

# -----------------------------------------------------------------------------
# LLM — IA de fallback (escolha um ou ambos)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Gateway de Pagamento (Rede — e.Rede REST API v1)
# Sandbox:  https://sandbox.userede.com.br/erede/v1
# Produção: https://api.userede.com.br/erede/v1
# -----------------------------------------------------------------------------
# Número de filiação Rede (PV)
REDE_PV=

# Token de integração e.Rede
REDE_INTEGRATION_TOKEN=

# Valor padrão da receita quando o CRM não retorna preço (R$)
PAYMENT_DEFAULT_AMOUNT=150.00

# Percentual de desconto no pagamento via PIX (ex: 5.0 = 5%)
PIX_DISCOUNT_PCT=5.0

# -----------------------------------------------------------------------------
# WhatsApp — Resiliência
# -----------------------------------------------------------------------------
# Número de tentativas de envio em caso de falha (com backoff exponencial)
WHATSAPP_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Segurança
# -----------------------------------------------------------------------------
# Segredo HMAC-SHA256 para validar assinatura do webhook do CRM.
# Gere um valor forte: python -c "import secrets; print(secrets.token_hex(32))"
# Se vazio, a verificação é ignorada (NÃO deixe vazio em produção).
WEBHOOK_SECRET=

# Limite de requisições ao /webhook por IP por minuto (produção)
WEBHOOK_RATE_LIMIT=60/minute

# -----------------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///nanoassist.db

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
# Valores: development | production
APP_ENV=development
LOG_LEVEL=INFO
